# ================================================
# Admin Propiedad Horizontal - Environment Template
# ================================================
# Opcional: copia este archivo a .env.local si quieres sobreescribir el modo demo
# NUNCA commitees el archivo .env.local con credenciales reales

# ================================================
# NextAuth Configuration
# ================================================
# Genera una clave segura con: openssl rand -base64 32
# Para demo local puedes usar un valor simple
AUTH_SECRET=demo-nextauth-secret-not-for-production
NEXTAUTH_URL=http://localhost:3001

# ================================================
# Google OAuth (Crea en https://console.cloud.google.com/)
# ================================================
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ================================================
# Backend API Configuration
# ================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
INTERNAL_API_URL=http://backend:8000/api
NEXT_PUBLIC_USE_MOCKS=true

# ================================================
# Google Sheets Integration (Service Account)
# ================================================
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# La private key debe estar en formato multilinea o base64
GOOGLE_PRIVATE_KEY=

# ================================================
# Optional: Sentry/Monitoring
# ================================================
# SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=
