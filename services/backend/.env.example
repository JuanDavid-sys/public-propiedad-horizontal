# ================================================
# Admin Propiedad Horizontal - Backend Environment
# ================================================
# Copia este archivo a .env y rellena con tus valores reales

# ================================================
# Django Core Settings
# ================================================
# Genera una clave segura con: openssl rand -base64 50
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================================
# Database Configuration
# ================================================
# Formato: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=
DATABASE_SSL=False

# ================================================
# CORS Configuration
# ================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ================================================
# JWT Configuration
# ================================================
# Opcional: cambiar duración de tokens (en minutos/horas)
# JWT_ACCESS_TOKEN_LIFETIME=60
# JWT_REFRESH_TOKEN_LIFETIME=10080

# ================================================
# Email Configuration (para notificaciones)
# ================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=

# ================================================
# File Storage (para documentos)
# ================================================
# Opcional: AWS S3 o Google Cloud Storage
# DEFAULT_FILE_STORAGE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# ================================================
# Optional: Sentry
# ================================================
# SENTRY_DSN=
